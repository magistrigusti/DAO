{
  "buildCommand": "cd apps/dom-mobile && npm install && npm run build && cp -r api ../.. && cp -r lib ../.. && cp -r static ../..",
  "outputDirectory": "apps/dom-mobile/dist",
  "installCommand": "cd apps/dom-mobile && npm install",
  "rewrites": [
    { "source": "/dom-metadata.json", "destination": "/api/metadata" },
    { "source": "/tonconnect-manifest.json", "destination": "/api/tonconnect-manifest" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
